
# Claude Vibe Bridge Configuration

# Authentication (Optional - enable to protect your service)
# AUTH_ENABLED=true
# AUTH_USERNAME=admin
# AUTH_PASSWORD=your_secure_password

# Server port
PORT=3900

# Sessions directory
SESSION_DIR=./data/sessions

# Allowed directories (separate with |)
ALLOWED_DIRS=E:\claude

# Agent settings
APPROVAL_MODE=auto
MAX_TOKENS=16384

# Anthropic API Key (if using direct API)
ANTHROPIC_API_KEY=
