
# Claude Vibe Bridge Configuration
# Copy this file to .env and customize as needed.
# Most settings auto-detect from Claude Desktop — you only need to configure auth and allowed dirs.

# === Authentication ===
# Enable to protect your service via HTTP Basic Auth.
# When enabled, both web and API access require username/password.
AUTH_ENABLED=true
AUTH_USERNAME=admin
AUTH_PASSWORD=vibridge123

# === Server ===
PORT=3900

# === Security ===
# Directories the server can access (pipe-separated).
ALLOWED_DIRS=E:\claude

# === Agent ===
# auto = tools execute without confirmation
# manual = write_file, edit_file, execute_command require browser approval
APPROVAL_MODE=auto
MAX_TOKENS=16384

# === Claude Desktop 3P (auto-detected, no manual config needed) ===
# These are auto-discovered from %LOCALAPPDATA%\Claude-3p\claude-code-sessions\
# Only set these if auto-detection fails (e.g. multiple Claude Desktop accounts):
# CLAUDE_DESKTOP_USER_ID=
# CLAUDE_DESKTOP_APP_ID=
